{
  "build": {
    "beforeBuildCommand": "",
    "devPath": "../frontend",
    "distDir": "../frontend"
  },
  "package": {
    "productName": "DiskRaptor",
    "version": "0.2.3"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true,
        "open": true
      },
      "fs": {
        "all": true,
        "readFile": true,
        "scope": ["**"]
      }
    },
    "systemTray": {
      "iconPath": "icons/128x128.png",
      "iconAsTemplate": true
    },
    "bundle": {
      "active": true,
      "identifier": "com.diskraptor.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/256x256.png",
        "icons/icon.ico",
        "icons/icon.icns"
      ],
      "targets": "all"
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "maximized": true,
        "resizable": true,
        "title": "DiskRaptor",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ]
  }
}
