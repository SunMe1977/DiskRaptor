{
  "build": {
    "beforeBuildCommand": "",
    "devPath": "../frontend",
    "distDir": "../frontend"
  },
  "package": {
    "productName": "DiskRaptor",
    "version": "0.2.4"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": true,
        "open": true
      },
      "fs": {
        "all": true,
        "readFile": true,
        "scope": ["**"]
      }
    },
    "systemTray": {
      "iconPath": "icons/128x128.png",
      "iconAsTemplate": true
    },
    "bundle": {
      "active": true,
      "identifier": "com.diskraptor.app",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/256x256.png",
        "icons/icon.ico",
        "icons/icon.icns"
      ],
      "targets": ["msi", "appimage", "dmg"],
      "category": "Utility",
      "shortDescription": "Ultra-fast disk space analyzer",
      "longDescription": "DiskRaptor is a modern, high-performance directory scanner built with Rust and Tauri. It scans directories at lightning speed and renders results in a virtual tree view capable of handling 10+ million files.",
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "maximized": true,
        "resizable": true,
        "title": "DiskRaptor",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ]
  }
}
